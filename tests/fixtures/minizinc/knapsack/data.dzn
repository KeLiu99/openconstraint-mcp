% Bounded knapsack instance chosen to actually exercise the "how many of each"
% decision: value densities vary (2.0 to 4.0 per unit weight) AND the optimal
% pack takes several copies of the densest small item, so this reads as bounded
% knapsack rather than 0/1. A greedy "take the densest until it no longer fits"
% rule is left short of the true optimum, so the solver earns its keep.

n = 6;

%             item:   1    2    3    4    5    6
weight    = [        15,  20,  33,  40,  25,  50];
value     = [        60,  70,  99, 120,  50, 110];
max_count = [         3,   2,   2,   1,   4,   1];

capacity = 100;
